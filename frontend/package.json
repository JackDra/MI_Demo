{
  "name": "mi-demo-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "vitest run"
  },
  "dependencies": {
    "@threlte/core": "8.5.16",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/kit": "2.57.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@types/node": "24.0.0",
    "@types/three": "0.184.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "17.4.0",
    "jsdom": "27.3.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.2",
    "svelte-check": "4.4.6",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.7",
    "vitest": "4.1.3"
  }
}
