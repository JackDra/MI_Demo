APP_ENV=dev
WEB_CONCURRENCY=1
DATABASE_URL=sqlite:///./mi_demo.db

# For Supabase/Postgres, set one of these to the pooler or direct connection string.
# SUPABASE_DB_URL=postgresql+psycopg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# For Supabase Storage assets, set these with a server-side service role key.
# The frontend never receives this key; it asks FastAPI for the public asset URL.
# SUPABASE_URL=https://[project-ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=[service-role-key]
# SUPABASE_STORAGE_BUCKET=mi-demo-assets

SQL_ECHO=false
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
